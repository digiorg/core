{
  "realm": "digiorg-core-platform",
  "enabled": true,
  "displayName": "DigiOrg Core Platform",
  "displayNameHtml": "<b>DigiOrg Core Platform</b>",
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "clients": [
    {
      "clientId": "argocd",
      "name": "ArgoCD",
      "description": "ArgoCD GitOps UI — OIDC login",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "argocd-client-secret",
      "redirectUris": [
        "https://digiorg.local/argocd/auth/callback",
        "https://digiorg.local/argocd/auth/callback"
      ],
      "webOrigins": [
        "https://digiorg.local/argocd",
        "https://digiorg.local/argocd"
      ],
      "protocol": "openid-connect",
      "publicClient": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": true,
      "protocolMappers": [
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "full.path": "false",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "groups",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "grafana",
      "name": "Grafana",
      "description": "Grafana Observability UI — OAuth2 login",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "grafana-client-secret",
      "redirectUris": [
        "https://digiorg.local/grafana/login/generic_oauth"
      ],
      "webOrigins": [
        "https://digiorg.local/grafana"
      ],
      "protocol": "openid-connect",
      "publicClient": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": true,
      "protocolMappers": [
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "full.path": "false",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "groups",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "backstage",
      "name": "Backstage Developer Portal",
      "description": "Backstage — OIDC login",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "backstage-client-secret",
      "redirectUris": [
        "https://digiorg.local/backstage/api/auth/oidc/handler/frame",
        "https://digiorg.local/backstage/*"
      ],
      "webOrigins": [
        "https://digiorg.local",
        "https://digiorg.local/backstage"
      ],
      "protocol": "openid-connect",
      "publicClient": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": true,
      "protocolMappers": [
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "full.path": "false",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "groups",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "gitea",
      "name": "Gitea",
      "description": "Gitea Git Service — OIDC login",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "gitea-client-secret",
      "redirectUris": [
        "https://digiorg.local/gitea/user/oauth2/Keycloak/callback",
        "https://digiorg.local/gitea/*"
      ],
      "webOrigins": [
        "https://digiorg.local",
        "https://digiorg.local/gitea"
      ],
      "protocol": "openid-connect",
      "publicClient": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": true,
      "protocolMappers": [
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "full.path": "false",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "groups",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "landingpage",
      "name": "Landing Page",
      "description": "DigiOrg Platform Landing Page — Public OIDC client",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "redirectUris": [
        "https://digiorg.local/*",
        "https://digiorg.local/*"
      ],
      "webOrigins": [
        "https://digiorg.local",
        "https://digiorg.local"
      ],
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": true,
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "full.path": "false",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "groups",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "jaeger",
      "name": "Jaeger",
      "description": "Jaeger Distributed Tracing UI — Keycloak SSO via oauth2-proxy",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "jaeger-client-secret",
      "redirectUris": [
        "https://digiorg.local/jaeger/oauth2/callback"
      ],
      "webOrigins": [
        "https://digiorg.local/jaeger"
      ],
      "protocol": "openid-connect",
      "publicClient": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": true,
      "protocolMappers": [
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "full.path": "false",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "groups",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "sonarqube",
      "name": "SonarQube",
      "description": "SonarQube Code Quality — Keycloak SSO via SAML",
      "enabled": true,
      "protocol": "saml",
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "fullScopeAllowed": true,
      "frontchannelLogout": true,
      "attributes": {
        "saml.authn.statement": "true",
        "saml.client.signature": "false",
        "saml.force.post.binding": "true",
        "saml.server.signature": "true",
        "saml_force_name_id_format": "true",
        "saml.assertion.signature": "false",
        "saml_name_id_format": "username",
        "saml.signature.algorithm": "RSA_SHA256"
      },
      "rootUrl": "https://digiorg.local",
      "baseUrl": "/sonarqube",
      "redirectUris": [
        "https://digiorg.local/sonarqube/oauth2/callback/saml",
        "https://digiorg.local/sonarqube/*"
      ],
      "webOrigins": [
        "https://digiorg.local/sonarqube"
      ],
      "protocolMappers": [
        {
          "name": "login",
          "protocol": "saml",
          "protocolMapper": "saml-user-property-mapper",
          "consentRequired": false,
          "config": {
            "attribute.nameformat": "Basic",
            "attribute.name": "login",
            "user.attribute": "username"
          }
        },
        {
          "name": "email",
          "protocol": "saml",
          "protocolMapper": "saml-user-property-mapper",
          "consentRequired": false,
          "config": {
            "attribute.nameformat": "Basic",
            "attribute.name": "email",
            "user.attribute": "email"
          }
        },
        {
          "name": "name",
          "protocol": "saml",
          "protocolMapper": "saml-user-property-mapper",
          "consentRequired": false,
          "config": {
            "attribute.nameformat": "Basic",
            "attribute.name": "name",
            "user.attribute": "firstName"
          }
        }
      ]
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "platform-admin",
        "description": "Full administrative access to the platform"
      },
      {
        "name": "platform-viewer",
        "description": "Read-only access to the platform"
      },
      {
        "name": "developer",
        "description": "Standard developer access"
      }
    ]
  },
  "groups": [
    {
      "name": "platform-admins",
      "realmRoles": [
        "platform-admin"
      ]
    },
    {
      "name": "platform-viewers",
      "realmRoles": [
        "platform-viewer"
      ]
    },
    {
      "name": "developers",
      "realmRoles": [
        "developer"
      ]
    }
  ]
}
