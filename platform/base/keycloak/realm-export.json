{
  "realm": "digiorg-core-platform",
  "enabled": true,
  "displayName": "DigiOrg Core Platform",
  "displayNameHtml": "<b>DigiOrg Core Platform</b>",
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "clients": [
    {
      "clientId": "argocd",
      "name": "ArgoCD",
      "description": "ArgoCD GitOps UI — OIDC login",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "argocd-client-secret",
      "redirectUris": [
        "http://digiorg.local/argocd/auth/callback",
        "http://digiorg.local/argocd/auth/callback"
      ],
      "webOrigins": [
        "http://digiorg.local/argocd",
        "http://digiorg.local/argocd"
      ],
      "protocol": "openid-connect",
      "publicClient": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": true,
      "protocolMappers": [
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "full.path": "false",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "groups",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "grafana",
      "name": "Grafana",
      "description": "Grafana Observability UI — OAuth2 login",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "grafana-client-secret",
      "redirectUris": [
        "http://digiorg.local/grafana/login/generic_oauth"
      ],
      "webOrigins": [
        "http://digiorg.local/grafana"
      ],
      "protocol": "openid-connect",
      "publicClient": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": true,
      "protocolMappers": [
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "full.path": "false",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "groups",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "backstage",
