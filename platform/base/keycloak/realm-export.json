  "roles": {
    "realm": [
      {
        "name": "platform-admin",
        "description": "Full administrative access to the platform"
      },
      {
        "name": "platform-viewer",
        "description": "Read-only access to the platform"
      },
      {
        "name": "developer",
        "description": "Standard developer access"
      }
    ]
  },
  "groups": [
    {
      "name": "platform-admins",
      "realmRoles": ["platform-admin"]
    },
    {
      "name": "platform-viewers",
      "realmRoles": ["platform-viewer"]
    },
    {
      "name": "developers",
      "realmRoles": ["developer"]
    }
  ],
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "email": "admin@example.com",
      "firstName": "Platform",
      "lastName": "Admin",
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": false
        }
      ],
      "realmRoles": ["platform-admin"],
      "groups": ["platform-admins"]
